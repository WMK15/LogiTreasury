# PayrollArena Frontend Environment Variables

# Contract Addresses (set after deployment)
NEXT_PUBLIC_PAYROLL_ARENA_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Chain Configuration
NEXT_PUBLIC_CHAIN_ID=1234
NEXT_PUBLIC_RPC_URL=https://rpc.arc.testnet
NEXT_PUBLIC_EXPLORER_URL=https://explorer.arc.testnet

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
