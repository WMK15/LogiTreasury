# LogiTreasury Frontend Environment Variables

# ============ NETWORK MODE ============
# Set to 'local' for Hardhat, 'testnet' for Arc Testnet
NEXT_PUBLIC_NETWORK_MODE=testnet

# ============ LOCAL HARDHAT ============
NEXT_PUBLIC_LOCAL_CHAIN_ID=31337
NEXT_PUBLIC_LOCAL_RPC_URL=http://127.0.0.1:8545

# Local Contract Addresses (populated by deploy script)
NEXT_PUBLIC_LOCAL_USDC_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_EURC_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_USYC_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_STABLEFX_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_TREASURY_MANAGER_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_YIELD_VAULT_ADAPTER_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_FX_ENGINE_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_SETTLEMENT_ROUTER_ADDRESS=0x0
NEXT_PUBLIC_LOCAL_CPN_GATEWAY_ADDRESS=0x0

# ============ ARC TESTNET ============
NEXT_PUBLIC_CHAIN_ID=5042002
NEXT_PUBLIC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_EXPLORER_URL=https://testnet.arcscan.app

# Arc Testnet Contract Addresses
NEXT_PUBLIC_USDC_ADDRESS=0x0
NEXT_PUBLIC_EURC_ADDRESS=0x0
NEXT_PUBLIC_USYC_ADDRESS=0x0
NEXT_PUBLIC_STABLEFX_ADDRESS=0x0
NEXT_PUBLIC_TREASURY_MANAGER_ADDRESS=0x0
NEXT_PUBLIC_YIELD_VAULT_ADAPTER_ADDRESS=0x0
NEXT_PUBLIC_FX_ENGINE_ADDRESS=0x0
NEXT_PUBLIC_SETTLEMENT_ROUTER_ADDRESS=0x0
NEXT_PUBLIC_CPN_GATEWAY_ADDRESS=0x0

# Legacy addresses (for backwards compatibility)
NEXT_PUBLIC_FREIGHT_ESCROW_ADDRESS=0x0
NEXT_PUBLIC_TREASURY_ADDRESS=0x0
NEXT_PUBLIC_SETTLEMENT_ADDRESS=0x0
NEXT_PUBLIC_BATCH_PAYROLL_ADDRESS=0x0

# ============ WALLET CONNECT ============
# Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# ============ API KEYS (Server-side only - no NEXT_PUBLIC_ prefix) ============
# StableFX API - for real FX rates and swaps
STABLEFX_API_KEY=your_stablefx_api_key
STABLEFX_API_URL=https://api.circle.com/v1/stablefx

# Circle API - for CPN integration
CIRCLE_API_KEY=your_circle_api_key
CIRCLE_API_URL=https://api.circle.com/v1
